# Environment Variables for RAG Setup
# Copy this file to .env and fill in your values

# Google/Gemini API (for embeddings and LLM)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API (alternative to Google)
# OPENAI_API_KEY=your_openai_api_key_here

# Qdrant Cloud (if using cloud instead of local)
# QDRANT_CLOUD_URL=https://your-cluster.qdrant.tech
# QDRANT_API_KEY=your_qdrant_api_key_here

# HuggingFace (if using HuggingFace models)
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Logging
LOG_LEVEL=INFO
